# Document Reader Backend Configuration
# COPY THIS FILE TO .env AND FILL IN YOUR SECRETS

# Flask Configuration
FLASK_DEBUG=True
FLASK_ENV=development

# File Upload Configuration
UPLOAD_FOLDER=uploads
MAX_FILE_SIZE=52428800

# Database Configuration
# REPLACE WITH YOUR ACTUAL CONNECTION STRING IN .env
# DO NOT COMMIT REAL CREDENTIALS
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
DB_NAME=aiDocDB

# Security
# Generate a secure key for production: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-secure-random-key

# Tesseract Configuration (Windows path)
# Adjust path if Tesseract is installed elsewhere
# Common Windows paths:
# C:/Program Files/Tesseract-OCR/tesseract.exe
# C:/Users/<User>/AppData/Local/Programs/Tesseract-OCR/tesseract.exe
TESSERACT_PATH=C:/Program Files/Tesseract-OCR/tesseract.exe

# Flask Server
FLASK_HOST=0.0.0.0
FLASK_PORT=5001
